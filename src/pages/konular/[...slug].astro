---
import { getCollection } from 'astro:content';
import KonuLayout from '../../layouts/KonuLayout.astro';

export async function getStaticPaths() {
  const konular = await getCollection('konular');
  return konular.map((konu) => ({
    params: { slug: konu.id },
    props: { konu },
  }));
}

const { konu } = Astro.props;
---

<KonuLayout konu={konu} />
